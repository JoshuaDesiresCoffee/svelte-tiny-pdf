{
    "name": "svelte-tiny-pdf",
    "version": "2.0.0",
    "description": "A tiny PDF viewer for Svelte",
    "homepage": "https://github.com/JoshuaDesiresCoffee/svelte-tiny-pdf",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/JoshuaDesiresCoffee/svelte-tiny-pdf.git"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "svelte": "./dist/index.js",
    "type": "module",
    "exports": {
        ".": {
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "svelte-package",
        "prepublishOnly": "svelte-package",
        "check": "svelte-check",
        "dev": "vite dev",
        "preview": "vite preview"
    },
    "keywords": [
        "svelte",
        "pdf",
        "pdf-viewer",
        "pdfjs",
        "pdfjs-dist"
    ],
    "author": "JoshuaDesiresCoffee",
    "license": "MIT",
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "peerDependencies": {
        "svelte": "^5.0.0"
    },
    "dependencies": {
        "pdfjs-dist": "^5.6.205"
    },
    "devDependencies": {
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^5.1.1",
        "svelte": "^5.55.4",
        "svelte-check": "^4.4.6",
        "vite": "^6.4.2"
    }
}
